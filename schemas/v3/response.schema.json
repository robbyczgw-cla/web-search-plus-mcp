      },
      "additionalProperties": false,
      "required": [
        "observation_id",
        "storage_attempted",
        "storage_succeeded",
        "reference",
        "full_text_sha256",
        "full_text_chars"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "storage_succeeded": {
                "const": true
              }
            },
            "required": [
              "storage_succeeded"
            ]
          },
          "then": {
            "properties": {
              "reference": {
                "$ref": "#/$defs/StoredContentReferenceV3"
              },
              "full_text_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "full_text_chars": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "else": {
            "properties": {
              "reference": {
                "type": "null"
              },
              "full_text_sha256": {
                "type": "null"
              },
              "full_text_chars": {
                "type": "null"
              }
            }
          }
        }
