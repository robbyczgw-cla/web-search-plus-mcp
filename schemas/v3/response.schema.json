      "type": "object",
      "properties": {
        "observation_id": {
          "type": "string",
          "pattern": "^obs_"
        },
        "storage_attempted": {
          "const": true
        },
        "storage_succeeded": {
          "type": "boolean"
        },
        "reference": {
          "anyOf": [
            {
              "$ref": "#/$defs/StoredContentReferenceV3"
            },
            {
              "type": "null"
            }
          ]
        },
        "full_text_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "full_text_chars": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
