{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": [
    "robbyczgw-cla"
  ],
  "name": "web-search-plus-mcp",
  "description": "Multi-provider web search, Tavily-first extraction, and onboarding for MCP server operators.",
  "repository": "https://github.com/robbyczgw-cla/web-search-plus-mcp",
  "homepage": "https://github.com/robbyczgw-cla/web-search-plus-mcp",
  "license": "MIT",
  "runtime": "python",
  "transport": [
    "stdio"
  ],
  "install": {
    "uvx": "uvx web-search-plus-mcp",
    "pip": "pip install web-search-plus-mcp"
  },
  "mcp": {
    "command": "uvx",
    "args": [
      "web-search-plus-mcp"
    ]
  },
  "tools": [
    {
      "name": "web_search",
      "description": "Search the web with intelligent auto-routing, provider override, quality reports, and optional research mode.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "provider": {
            "type": "string",
            "description": "Provider override",
            "enum": [
              "auto",
              "serper",
              "brave",
              "tavily",
              "exa",
              "querit",
              "linkup",
              "firecrawl",
              "perplexity",
              "kilo-perplexity",
              "you",
              "searxng",
              "serpbase"
            ],
            "default": "auto"
          },
          "count": {
            "type": "integer",
            "description": "Number of results",
            "default": 5
          },
          "depth": {
            "type": "string",
            "enum": [
              "normal",
              "deep",
              "deep-reasoning"
            ],
            "default": "normal"
          },
          "time_range": {
            "type": "string",
            "enum": [
              "hour",
              "day",
              "week",
              "month",
              "year"
            ]
          },
          "include_domains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exclude_domains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mode": {
            "type": "string",
            "enum": [
              "normal",
              "research"
            ],
            "default": "normal"
          },
          "quality_report": {
            "type": "boolean",
            "default": false
          },
          "research_time_budget": {
            "type": "number",
            "default": 55.0
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "web_extract",
      "description": "Extract markdown or HTML from URLs via Tavily, Exa, Linkup, Firecrawl, or You.com.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "provider": {
            "type": "string",
            "enum": [
              "auto",
              "tavily",
              "exa",
              "linkup",
              "firecrawl",
              "you"
            ],
            "default": "auto"
          },
          "format": {
            "type": "string",
            "enum": [
              "markdown",
              "html"
            ],
            "default": "markdown"
          },
          "include_images": {
            "type": "boolean",
            "default": false
          },
          "include_raw_html": {
            "type": "boolean",
            "default": false
          },
          "render_js": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "urls"
        ]
      }
    }
  ],
  "features": {
    "autoRouting": true,
    "qualityReports": true,
    "researchMode": true,
    "webAnswerBeta": false,
    "onboardingCli": true,
    "routingConfigCli": true,
    "providers": [
      "serper",
      "brave",
      "tavily",
      "exa",
      "querit",
      "linkup",
      "firecrawl",
      "perplexity",
      "kilo-perplexity",
      "you",
      "searxng"
    ],
    "extractProviders": [
      "tavily",
      "exa",
      "linkup",
      "firecrawl",
      "you"
    ]
  }
}
